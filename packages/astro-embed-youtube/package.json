{
  "name": "@astro-community/astro-embed-youtube",
  "version": "0.5.10",
  "description": "Component to easily embed YouTube videos on your Astro site",
  "type": "module",
  "scripts": {
    "prepack": "tsc -p tsconfig.build.json"
  },
  "exports": {
    ".": "./index.ts",
    "./matcher": {
      "types": "./dist/matcher.d.ts",
      "default": "./dist/matcher.js"
    }
  },
  "files": [
    "index.ts",
    "matcher.ts",
    "dist",
    "YouTube.astro"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/delucis/astro-embed",
    "directory": "packages/astro-embed-youtube"
  },
  "keywords": [
    "astro",
    "astro-component",
    "ui",
    "embeds",
    "youtube"
  ],
  "author": "delucis",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/delucis/astro-embed/issues"
  },
  "homepage": "https://astro-embed.netlify.app/components/youtube/",
  "dependencies": {
    "lite-youtube-embed": "^0.3.4"
  }
}
